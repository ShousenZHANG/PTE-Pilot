{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!.superpowers",
      "!**/.claude",
      "!**/.wxt",
      "!**/.output",
      "!**/node_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!tests/fixtures",
      "!PTE-Pilot-Chrome-latest",
      "!PTE-Pilot-*-chrome",
      "!packages/*/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
